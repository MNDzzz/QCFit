						"body": { "mode": "formdata", "formdata": [{"key":"image_url","value":"https://example.com/image.jpg","type":"text"}] },
						"url": { "raw": "{{base_url}}/api/ai/remove-bg", "host": ["{{base_url}}"], "path": ["api","ai","remove-bg"] }
					}
				}
			]
		}
	]
}
